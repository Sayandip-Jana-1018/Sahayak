{
  "name": "sahayak",
  "version": "1.0.0",
  "private": true,
  "description": "Sahayak — India's voice-first AI for elderly smartphones",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@sahayak/web",
    "dev:api": "turbo run dev --filter=@sahayak/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@sahayak/web",
    "build:api": "turbo run build --filter=@sahayak/api",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "turbo run db:generate --filter=@sahayak/db",
    "db:migrate": "turbo run db:migrate --filter=@sahayak/db",
    "db:push": "turbo run db:push --filter=@sahayak/db"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
